# 火山引擎 Access Key 和 Secret Key
# 获取地址：https://console.volcengine.com/iam/keymanage
VOLC_ACCESS_KEY=your-access-key-here
VOLC_SECRET_KEY=your-secret-key-here

# 区域配置（可选：cn-beijing, cn-shanghai, cn-guangzhou, ap-singapore 等）
VOLC_REGION=cn-beijing

# OpenClaw 工作区路径（用于日志记录）
VOLC_WORKSPACE_PATH=~/.openclaw/workspace

# 飞书接收者 ID
FEISHU_RECEIVER_ID=ou_xxxxxxxxxxxxxxxx
